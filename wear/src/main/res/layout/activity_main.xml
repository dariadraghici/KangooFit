<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_reps_watch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alege Exercițiul"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/layout_start_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_start_pushups"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Flotări"
                android:backgroundTint="#00A859"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btn_start_squats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#00A859"
                android:text="Start Genuflexiuni" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_stop_exercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop Antrenament"
            android:backgroundTint="#D32F2F"
            android:visibility="gone" />

    </LinearLayout>
</androidx.wear.widget.BoxInsetLayout>