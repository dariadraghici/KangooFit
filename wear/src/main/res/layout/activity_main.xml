<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/layout_start_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose Exercise"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <Button android:id="@+id/btn_start_pushups" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Start Push-ups" android:backgroundTint="#00A859" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btn_start_squats" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Start Squats" android:backgroundTint="#00A859" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btn_start_jacks" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Start Jumping Jacks" android:backgroundTint="#00A859" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btn_start_biceps" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Start Bicep Curls" android:backgroundTint="#00A859" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btn_start_shoulder" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Start Shoulder Press" android:backgroundTint="#00A859"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_active_workout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_active_exercise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exercise Name"
                    android:textColor="#00A859"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_active_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: Loading..."
                    android:textColor="#FFEB3B"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_active_reps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reps: 0"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_active_bpm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BPM: --"
                    android:textColor="#FF5252"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btn_stop_exercise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Stop Workout"
                    android:backgroundTint="#D32F2F" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.wear.widget.BoxInsetLayout>