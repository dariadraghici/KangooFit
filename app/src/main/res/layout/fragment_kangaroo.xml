<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ===== FIXED BOTTOM PANEL ===== -->
    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@android:color/white"
        android:elevation="8dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progress to next level"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Overall bar -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_overall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:trackThickness="10dp"
            app:trackCornerRadius="5dp"
            app:indicatorColor="#FF8C00"
            app:trackColor="#33FF8C00"/>

        <!-- SQUATS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🏋 Squats"
                android:textSize="15sp"/>
            <TextView
                android:id="@+id/tv_squats_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 50"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <ProgressBar
            android:id="@+id/progress_squats"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#FF8C00"
            android:layout_marginBottom="10dp"/>

        <!-- PUSH-UPS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💪 Push-ups"
                android:textSize="15sp"/>
            <TextView
                android:id="@+id/tv_pushups_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 30"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <ProgressBar
            android:id="@+id/progress_pushups"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#4CAF50"
            android:layout_marginBottom="10dp"/>

        <!-- PULL-UPS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔝 Pull-ups"
                android:textSize="15sp"/>
            <TextView
                android:id="@+id/tv_pullups_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— / —"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <ProgressBar
            android:id="@+id/progress_pullups"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#2196F3"
            android:layout_marginBottom="10dp"/>

        <!-- STEPS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="👟 Steps"
                android:textSize="15sp"/>
            <TextView
                android:id="@+id/tv_steps_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 1000"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <ProgressBar
            android:id="@+id/progress_steps"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#9C27B0"
            android:layout_marginBottom="0dp"/>

    </LinearLayout>

    <!-- ===== TOP CONTENT — kangaroo fills remaining space ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Level number -->
        <TextView
            android:id="@+id/tv_level_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEVEL 1"
            android:textSize="13sp"
            android:textColor="#FF8C00"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="2dp"/>

        <!-- Stage name -->
        <TextView
            android:id="@+id/tv_level_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Newborn Joey"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="0dp"/>

        <!-- KANGAROO IMAGE — takes all remaining space -->
        <ImageView
            android:id="@+id/img_kangaroo"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scaleType="fitCenter"
            android:src="@drawable/kangur_1"
            android:contentDescription="Kangaroo current level"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <!-- Next level label -->
        <TextView
            android:id="@+id/tv_next_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next: Small Joey"
            android:textSize="13sp"
            android:alpha="0.55"
            android:layout_marginBottom="310dp"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>